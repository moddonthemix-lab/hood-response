# ─── Server ────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production

# ─── Robinhood Chain ─────────────────────────────────────────────────────────
# WebSocket RPC endpoint for Robinhood Chain. Leave blank to run in SIMULATOR
# mode, which replays synthetic coordinated swaps against the seeded wallets so
# the whole pipeline (detection → alerts → dashboard) is exercised end-to-end.
CHAIN_WS_URL=
CHAIN_HTTP_URL=
CHAIN_ID=

# Force the data source: "live" (requires CHAIN_WS_URL) or "simulator".
# Defaults to "simulator" when CHAIN_WS_URL is empty, otherwise "live".
CHAIN_MODE=simulator
# Simulator cadence (ms) and probability [0..1] of firing a coordinated swarm.
SIM_TICK_MS=1500
SIM_SWARM_CHANCE=0.35

# ─── Alert rules (defaults; overridable per-rule via API) ─────────────────────
ALERT_MIN_WALLETS=3
ALERT_WINDOW_SECONDS=30
ALERT_MIN_USD=0
ALERT_MIN_CONVICTION=0
ALERT_COOLDOWN_SECONDS=120
IGNORE_DUST_USD=25
IGNORE_STABLECOINS=true

# ─── Notifications (all optional; each channel is skipped if unset) ───────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GENERIC_WEBHOOK_URL=

# ─── Optional persistence / cache (bot runs fully in-memory without these) ────
DATABASE_URL=
REDIS_URL=
