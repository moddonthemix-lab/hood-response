# ─── Server ────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production

# ─── Robinhood Chain (chain id 4663) ─────────────────────────────────────────
# The bot ships LIVE by default: it polls the public Robinhood Chain HTTP RPC
# below for tracked-wallet activity. Point CHAIN_WS_URL at a streaming provider
# (Alchemy/QuickNode) for lower-latency websocket subscriptions instead.
CHAIN_WS_URL=
CHAIN_HTTP_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663

# Data source: "auto" (live when an RPC is set, else simulator), "live", or
# "simulator" (synthetic swaps — no chain needed, good for demos).
CHAIN_MODE=auto
# HTTP polling cadence (ms) for the public-RPC listener.
POLL_INTERVAL_MS=4000
# Simulator cadence (ms) and probability [0..1] of firing a coordinated swarm.
SIM_TICK_MS=1500
SIM_SWARM_CHANCE=0.35
# Fraction of simulated swarms that target a brand-new (unseen) token.
SIM_DISCOVERY_CHANCE=0.4

# Discovery mode: alert when tracked wallets swarm into ANY token — including
# brand-new coins not in the seed list — auto-registering the unknown token.
# Set false to watch only the seeded/tracked tokens (legacy behaviour).
DISCOVERY_MODE=true

# ─── Alert rules (defaults; overridable per-rule via API) ─────────────────────
ALERT_MIN_WALLETS=2
ALERT_WINDOW_SECONDS=300
ALERT_MIN_USD=0
ALERT_MIN_CONVICTION=0
# Global floors for EVERY alert type: skip tokens under this market cap and
# pairs younger than this age (minutes).
ALERT_MIN_MARKETCAP=25000
PAIR_MIN_AGE_MINUTES=30
# Solo-buy alerts: alert when a single tracked wallet buys a coin, but only if
# its market cap is under SOLO_MAX_MARKETCAP (catch early low-cap entries).
SOLO_ALERTS=true
# Solo buys only alert when market cap is within this range (early but not dust).
SOLO_MIN_MARKETCAP=25000
SOLO_MAX_MARKETCAP=125000

# Safety filter: suppress alerts for rugs/honeypots. Runs GoPlus token-security
# (honeypot, buy/sell tax, mintable, LP lock, ownership) + a minimum liquidity
# check. Set SAFETY_FILTER=false to alert on everything.
SAFETY_FILTER=true
SAFETY_MIN_LIQUIDITY_USD=5000
SAFETY_MAX_TAX_PCT=15

# Volume/momentum confirmation. Confirmed momentum boosts conviction + shows in
# alerts. Set > 0 to also suppress alerts on tokens with 24h volume below this
# (0 keeps brand-new gems that have little volume yet).
MOMENTUM_MIN_VOLUME_USD=0

# Fresh-pair + first-entry alerts: fire when a qualifying-tier wallet makes its
# first-ever buy of a token whose pair is younger than FRESH_PAIR_MAX_AGE_HOURS.
FRESH_ENTRY_ALERTS=true
FRESH_PAIR_MAX_AGE_HOURS=48
FRESH_ENTRY_TIERS=alpha,beta
ALERT_COOLDOWN_SECONDS=120
# Rolling window for the repeat/escalation counter: alerts report how many times
# the same token has alerted within this many minutes ("3rd alert in 35m").
REPEAT_WINDOW_MINUTES=35
# Mute tracked wallets by the coin they came from (e.g. HMM). A wallet is only
# silenced when EVERY coin it's a top-holder of is muted, so cross-holders that
# also hold other gems keep firing. Toggle live at runtime via /api/muted or the
# dashboard "Wallet Groups" card. Comma-separated, case-insensitive.
MUTE_WALLET_TOKENS=
IGNORE_DUST_USD=25
IGNORE_STABLECOINS=true
# Symbols never treated as gems: settlement/quote tokens + tokenised equities
# the tracked wallets trade heavily. Comma-separated, case-insensitive.
IGNORE_SYMBOLS=WETH,WBTC,ETH,USDC,USDT,USDG,DAI,USDB,WROB,VIRTUAL,AAPL,TSLA,NVDA,GOOGL,GOOG,META,MSFT,AMZN,AMD,INTC,MU,NFLX,DIS,COIN,PLTR,ORCL,CRWV,SNDK,SPCX,USAR,BE,HOOD,SPY,QQQ

# ─── Notifications (all optional; each channel is skipped if unset) ───────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GENERIC_WEBHOOK_URL=

# ─── Optional persistence / cache (bot runs fully in-memory without these) ────
DATABASE_URL=
REDIS_URL=

# ─── DexScreener prices + links ──────────────────────────────────────────────
# Chain slug for real prices / market caps and direct token pages. Robinhood
# Chain's slug is "robinhood" (the default). Blank falls back to synthetic
# prices and universal address-search links.
DEXSCREENER_CHAIN=robinhood
# How often (ms) to refresh live prices from DexScreener.
PRICE_REFRESH_MS=15000
